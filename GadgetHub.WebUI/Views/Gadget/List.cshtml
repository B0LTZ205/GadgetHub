@model GadgetHub.WebUI.Models.GadgetsListViewModel

@{

    ViewBag.Title = "Gadgets";

}

<div class="container mt-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-white py-3">
            <div class="row align-items-center">
                <div class="col">
                    <h3 class="mb-0 fw-bold text-dark">Product Catalog</h3>
                    <p class="text-muted small mb-0">Showing @Model.PagingInfo.TotalItems gadgets available</p>
                </div>
                <div class="col-auto">
                    @if (Model.CurrentCategory != null)
                    {
                        <span class="badge rounded-pill bg-info text-dark px-3">@Model.CurrentCategory</span>
                    }
                </div>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Name</th>
                        <th>Brand</th>
                        <th>Category</th>
                        <th class="text-center">Price</th>
                        <th class="w-25">Description</th>
                        <th class="text-center pe-4">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var g in Model.Gadgets)
                    {
                        @Html.Partial("GadgetSummary", g)
                    }
                </tbody>
            </table>
        </div>

        <div class="card-footer bg-white py-3">
            <div class="d-flex justify-content-center">
                <nav>
                    <div class="pagination-wrapper">
                        @Html.PageLinks(Model.PagingInfo, x => Url.Action("List", new { page = x, category = Model.CurrentCategory }))
                    </div>
                </nav>
            </div>
        </div>
    </div>
</div>

<style>
    /* Styling the Custom PageLinks Helper Output */
    .pagination-wrapper a {
        display: inline-block;
        padding: 0.5rem 1rem;
        margin: 0 2px;
        text-decoration: none;
        background-color: #fff;
        border: 1px solid #dee2e6;
        border-radius: 4px;
        color: #0d6efd;
        transition: all 0.2s;
    }

        .pagination-wrapper a:hover {
            background-color: #e9ecef;
        }

        .pagination-wrapper a.selected { /* Assuming your helper applies a 'selected' class */
            background-color: #0d6efd;
            color: white;
            border-color: #0d6efd;
        }
</style>