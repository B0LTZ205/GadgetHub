@model IEnumerable<string>

<div class="category-ribbon bg-white shadow-sm mb-4 border-bottom border-top">
    <div class="container">
        <nav class="nav nav-pills d-flex flex-nowrap overflow-auto py-2">
            @Html.ActionLink("All Gadgets", "List", "Gadget", null, new
            {
                @class = "nav-link rounded-pill me-2 " + (ViewBag.SelectedCategory == null ? "active shadow-sm" : "text-secondary hover-pill")
            })

            @foreach (var link in Model)
            {
                @Html.RouteLink(link, new
                {
                    controller = "Gadget",
                    action = "List",
                    category = link,
                    page = 1
                }, new
                {
                    @class = "nav-link rounded-pill me-2 "
                             + (link == ViewBag.SelectedCategory ? "active shadow-sm" : "text-secondary hover-pill")
                })
            }
        </nav>
    </div>
</div>

<style>
    /* Hide scrollbar but keep scrolling functionality for mobile */
    .overflow-auto::-webkit-scrollbar {
        display: none;
    }

    .overflow-auto {
        -ms-overflow-style: none;
        scrollbar-width: none;
    }

    /* Pill styling */
    .category-ribbon .nav-link {
        white-space: nowrap; /* Prevents text from wrapping */
        padding: 0.5rem 1.25rem;
        font-weight: 500;
        font-size: 0.95rem;
        transition: all 0.2s ease-in-out;
    }

        /* Active State */
        .category-ribbon .nav-link.active {
            background-color: #0d6efd;
            color: white !important;
        }

    /* Hover State for non-active */
    .hover-pill:hover {
        background-color: #f0f2f5;
        color: #0d6efd !important;
        transform: translateY(-1px);
    }

    .category-ribbon {
        background: #ffffff;
        position: sticky; /* Optional: keeps the bar at the top as you scroll */
        top: 0;
        z-index: 1020;
    }
</style>