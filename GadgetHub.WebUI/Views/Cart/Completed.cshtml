@model GadgetHub.Domain.Entities.ShippingDetails

@{
    ViewBag.Title = "SportStore: Order Completed";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-sm border-success">
                <div class="card-header bg-success text-white">
                    <h2 class="mb-0 h4">Order Completed</h2>
                </div>

                <div class="card-body p-4 text-center">
                    <div class="mb-4">
                        <i class="fas fa-check-circle text-success" style="font-size: 3rem;"></i>
                    </div>

                    <h3 class="mb-3">Thank You, @Model.Name!</h3>

                    <p class="text-muted mb-4">
                        Your order has been successfully processed and will be shipped to your address shortly.
                    </p>

                    <h5 class="border-bottom pb-3 mb-3">Shipping Details</h5>

                    <div class="text-start">
                        <p><strong>Name:</strong> @Model.Name</p>
                        <p>
                            <strong>Address:</strong><br />
                            @Model.Line1<br />
                            @if (!string.IsNullOrEmpty(Model.Line2))
                            {
                                @Model.Line2<br />
                            }
                            @if (!string.IsNullOrEmpty(Model.Line3))
                            {
                                @Model.Line3<br />
                            }
                        </p>
                        <p>
                            @Model.City, @Model.State @Model.Zip<br />
                            @Model.Country
                        </p>
                        @if (Model.GiftWrap)
                        {
                            <p><strong>Gift Wrap:</strong> <span class="badge bg-info">Yes</span></p>
                        }
                    </div>

                    <div class="mt-4">
                        @Html.ActionLink("Back to Shopping", "Index", "Gadget", new { @class = "btn btn-primary" })
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>