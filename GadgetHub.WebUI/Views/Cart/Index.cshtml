@model GadgetHub.WebUI.Models.CartIndexViewModel

@{

    ViewBag.Title = "Gadgets Store: Your Cart";

}

<div class="container mt-5">
    <div class="card shadow-sm">
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
            <h2 class="h4 mb-0">Your Shopping Cart</h2>
            <span class="badge bg-light text-dark">@Model.Cart.Lines.Count() Items</span>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Item Description</th>
                            <th class="text-center">Price</th>
                            <th class="text-center">Quantity</th>
                            <th class="text-end">Subtotal</th>
                            <th class="text-center">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var line in Model.Cart.Lines)
                        {
                            <tr>
                                <td class="ps-4">
                                    <span class="fw-bold text-primary">@line.Gadget.Name</span>
                                </td>
                                <td class="text-center">@line.Gadget.Price.ToString("c")</td>
                                <td class="text-center">
                                    <span class="badge rounded-pill bg-secondary px-3">@line.Quantity</span>
                                </td>
                                <td class="text-end fw-bold">
                                    @((line.Quantity * line.Gadget.Price).ToString("c"))
                                </td>
                                <td class="text-center">
                                    @using (Html.BeginForm("RemoveFromCart", "Cart"))
                                    {
                                        @Html.Hidden("GadgetId", line.Gadget.GadgetId)
                                        @Html.Hidden("returnUrl", Model.ReturnUrl)
                                        <button type="submit" class="btn btn-outline-danger btn-sm">
                                            <i class="bi bi-trash"></i> Remove
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="table-light">
                        <tr class="fs-5">
                            <td colspan="3" class="text-end fw-bold ps-4">Grand Total:</td>
                            <td class="text-end fw-bold text-success">
                                @Model.Cart.ComputeTotalValue().ToString("c")
                            </td>
                            <td></td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>

        <div class="card-footer bg-white p-4">
            <div class="d-flex justify-content-between align-items-center">
                <a href="@Model.ReturnUrl" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left"></i> Continue Shopping
                </a>
                @Html.ActionLink("Proceed to Checkout", "Checkout", null, new { @class = "btn btn-primary btn-lg px-5 shadow-sm" })
            </div>
        </div>
    </div>
</div>