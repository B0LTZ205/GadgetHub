@model GadgetHub.WebUI.Models.CartIndexViewModel

@{
    ViewBag.Title = "Gadgets Store: Your Cart";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Mono:wght@300;400&display=swap');

    :root {
        --bg: #0d0d0f;
        --surface: #16161a;
        --border: #2a2a30;
        --accent: #c8f135;
        --accent-dim: rgba(200, 241, 53, 0.08);
        --text-primary: #f0f0ee;
        --text-muted: #6b6b78;
        --text-price: #c8f135;
    }

    .gadget-catalog-wrapper {
        font-family: 'Syne', sans-serif;
        background: var(--bg);
        min-height: 100vh;
        padding: 3rem 2rem;
    }

    .catalog-header {
        display: flex;
        align-items: baseline;
        gap: 1rem;
        margin-bottom: 2.5rem;
    }

        .catalog-header h2 {
            font-size: 2.4rem;
            font-weight: 800;
            color: var(--text-primary);
            letter-spacing: -0.03em;
            margin: 0;
            line-height: 1;
        }

    .gadget-table-container {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 24px 64px rgba(0,0,0,0.5);
    }

    .gadget-table {
        width: 100%;
        border-collapse: collapse;
    }

        .gadget-table thead tr {
            border-bottom: 1px solid var(--border);
            background: rgba(255,255,255,0.02);
        }

        .gadget-table thead th {
            font-family: 'DM Mono', monospace;
            font-size: 0.65rem;
            font-weight: 400;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: var(--text-muted);
            padding: 1rem 1.4rem;
            text-align: left;
            white-space: nowrap;
        }

            .gadget-table thead th.col-price,
            .gadget-table thead th.col-quantity {
                text-align: right;
            }

        .gadget-table tbody tr {
            border-bottom: 1px solid rgba(255,255,255,0.04);
            transition: background 0.15s ease;
        }

            .gadget-table tbody tr:last-child {
                border-bottom: none;
            }

            .gadget-table tbody tr:hover {
                background: var(--accent-dim);
            }

        .gadget-table tbody td {
            padding: 1.1rem 1.4rem;
            color: var(--text-primary);
            font-size: 0.92rem;
            vertical-align: middle;
        }

    .td-name {
        font-weight: 700;
        font-size: 0.95rem;
        letter-spacing: -0.01em;
    }

    .td-price, .td-subtotal {
        text-align: right;
        font-family: 'DM Mono', monospace;
        font-weight: 400;
        font-size: 0.95rem;
        color: var(--text-price);
        letter-spacing: -0.01em;
    }

    .td-quantity {
        text-align: right;
        font-family: 'DM Mono', monospace;
    }

    .gadget-table tfoot td {
        padding: 1.5rem 1.4rem;
        font-weight: 700;
        font-size: 1.1rem;
        color: var(--text-primary);
        text-align: right;
        border-top: 1px solid var(--border);
    }

    .gadget-table tfoot .total-label {
        font-family: 'DM Mono', monospace;
        font-size: 0.7rem;
        font-weight: 400;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--text-muted);
    }

    .cart-actions {
        padding: 1.5rem 0;
        text-align: right;
    }

    .btn-continue {
        font-family: 'Syne', sans-serif;
        font-weight: 600;
        font-size: 0.9rem;
        letter-spacing: 0.02em;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        height: 3rem;
        padding: 0 2rem;
        border-radius: 8px;
        border: 1px solid var(--border);
        color: var(--text-primary);
        background: var(--surface);
        text-decoration: none;
        transition: all 0.2s ease;
    }

        .btn-continue:hover {
            background: var(--accent);
            color: var(--bg);
            border-color: var(--accent);
        }

    .td-remove form {
        display: flex;
    }

    .btn-remove {
        font-family: 'DM Mono', monospace;
        font-size: 0.7rem;
        letter-spacing: 0.06em;
        padding: 0.25rem 0.75rem;
        border-radius: 2rem;
        background: rgba(255, 80, 80, 0.1);
        color: #ff8080;
        border: 1px solid rgba(255, 80, 80, 0.2);
        text-transform: uppercase;
        cursor: pointer;
        transition: all 0.2s ease;
    }

        .btn-remove:hover {
            background: #ff5050;
            color: var(--text-primary);
            border-color: #ff5050;
        }
</style>

<div class="gadget-catalog-wrapper">
    <div class="catalog-header">
        <h2>Your Cart</h2>
    </div>

    <div class="gadget-table-container">
        <table class="gadget-table">
            <thead>
                <tr>
                    <th>Item</th>
                    <th class="col-price">Price</th>
                    <th class="col-quantity">Quantity</th>
                    <th class="col-price">Subtotal</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var line in Model.Cart.Lines)
                {
                    <tr>
                        <td class="td-name">@line.Gadget.Name</td>
                        <td class="td-price">@line.Gadget.Price.ToString("c")</td>
                        <td class="td-quantity">@line.Quantity</td>
                        <td class="td-subtotal">@((line.Quantity * line.Gadget.Price).ToString("c"))</td>
                        <td class="td-remove">
                            @using (Html.BeginForm("RemoveFromCart", "Cart"))
                            {
                                @Html.Hidden("GadgetId", line.Gadget.GadgetId)
                                @Html.Hidden("returnUrl", Model.ReturnUrl)
                                <input class="btn-remove" type="submit" value="Remove" />
                            }
                        </td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr>
                    <td colspan="3" class="total-label">Total</td>
                    <td class="td-price">
                        @Model.Cart.ComputeTotalValue().ToString("c")
                    </td>
                    <td></td>
                </tr>
            </tfoot>
        </table>
    </div>

    <div class="cart-actions">
        <a href="@Model.ReturnUrl" class="btn-continue">Continue shopping</a>
        @Html.ActionLink("Checkout now", "Checkout", null, new { @class = "btn-continue" })
    </div>
</div>